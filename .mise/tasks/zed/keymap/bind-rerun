#!/usr/bin/env bash
#MISE description="Bind a Zed key to rerun the last task"
#MISE dir="{{config_root}}"
#USAGE flag "--keystroke <keystroke>" required=#true help="Zed key binding, for example cmd-shift-r"
#USAGE flag "--context <context>" default="Workspace" help="Zed keymap context"
#USAGE flag "--reevaluate-context" default=#true help="Reevaluate Zed task variables before rerun"
#USAGE flag "--force" default=#false help="Replace an existing different binding"
#USAGE example "mise run zed:keymap:bind-rerun --keystroke cmd-shift-r --reevaluate-context" header="Bind task rerun"
set -euo pipefail

source "$MISE_CONFIG_ROOT/lib/zed/keymap.sh"

binding_json=$(jq -n --argjson reevaluate "$usage_reevaluate_context" '["task::Rerun", {reevaluate_context: $reevaluate}]')
zed_keymap_upsert_binding_json "$usage_context" "$usage_keystroke" "$binding_json" "$usage_force"
