#!/usr/bin/env bash
#MISE description="Bind a Zed key to spawn a named task"
#MISE dir="{{config_root}}"
#USAGE flag "--keystroke <keystroke>" required=#true help="Zed key binding, for example cmd-shift-d"
#USAGE flag "--task <task>" required=#true help="Zed task label to spawn"
#USAGE flag "--context <context>" default="Workspace" help="Zed keymap context"
#USAGE flag "--force" default=#false help="Replace an existing different binding"
#USAGE example "mise run zed:keymap:bind-task --keystroke cmd-shift-d --task 'comments: dispatch current file'" header="Bind a task"
set -euo pipefail

source "$MISE_CONFIG_ROOT/lib/zed/keymap.sh"

binding_json=$(jq -n --arg task "$usage_task" '["task::Spawn", {task_name: $task}]')
zed_keymap_upsert_binding_json "$usage_context" "$usage_keystroke" "$binding_json" "$usage_force"
