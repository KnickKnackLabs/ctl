#!/usr/bin/env bash
#MISE description="Run BATS tests"
#MISE dir="{{config_root}}"
#USAGE arg "[args]" default="" var=#true help="Test suites or bats arguments"
#USAGE example "mise run test" header="Run all tests"
#USAGE example "mise run test skeleton" header="Run a specific suite by name"
#USAGE example "mise run test --filter doctor" header="Filter tests by name"
set -euo pipefail

TEST_DIR="$MISE_CONFIG_ROOT/test"

args=()
if [ -n "${usage_args:-}" ]; then
  while IFS= read -r arg; do
    [ -z "$arg" ] && continue
    args+=("$arg")
  done < <(printf '%s' "${usage_args}" | xargs printf '%s\n')
fi

resolved=()
has_target=false

append_bats_files_in_dir() {
  local dir="$1"
  while IFS= read -r file; do
    resolved+=("$file")
  done < <(find "$dir" -type f -name '*.bats' | sort)
}

for arg in ${args[@]+"${args[@]}"}; do
  if [[ "$arg" != -* && "$arg" != *.bats && -f "$TEST_DIR/$arg.bats" ]]; then
    resolved+=("$TEST_DIR/$arg.bats")
    has_target=true
  elif [[ "$arg" != -* && -d "$TEST_DIR/$arg" ]]; then
    append_bats_files_in_dir "$TEST_DIR/$arg"
    has_target=true
  elif [[ -d "$arg" ]]; then
    append_bats_files_in_dir "$arg"
    has_target=true
  else
    [[ "$arg" == *.bats ]] && has_target=true
    resolved+=("$arg")
  fi
done

if ! $has_target; then
  append_bats_files_in_dir "$TEST_DIR"
fi

exec bats --print-output-on-failure "${resolved[@]}"
